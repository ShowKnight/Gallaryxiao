# Copy this file to .env.local (gitignored). Fill the values from
# Volcano Engine console. Never commit .env.local.
#
# Where to find each value:
#
# VOLC_ACCESS_KEY_ID / VOLC_SECRET_ACCESS_KEY
#   控制台右上头像 → "访问控制" → "API 访问密钥" → 创建子用户 +
#   只勾 ImageXFullAccess 策略 → 给该子用户创建 AccessKey。
#   把 AK/SK 复制下来，SK 只显示一次。
#
# VEIMAGEX_SERVICE_ID
#   veImageX 控制台 → "服务" 列表里的 "ServiceID" 列。
#
# VOLC_REGION
#   通常是 cn-north-1（默认）；新加坡服务用 ap-singapore-1。
#
# VEIMAGEX_KEY_PREFIX
#   可选。所有这次上传的 key 都会带上这个前缀（一个文件夹概念）。
#   适合按系列分组，例如 "letters" 或 "journal/2024".
#
# 用于 astro.config / 运行时（同时填到 Cloudflare Pages 环境变量）:
# PUBLIC_IMAGE_HOST 是 veImageX 给你的访问域名（控制台 → 服务 → 域名管理）。

VOLC_ACCESS_KEY_ID=
VOLC_SECRET_ACCESS_KEY=
VOLC_REGION=cn-north-1
VEIMAGEX_SERVICE_ID=
VEIMAGEX_KEY_PREFIX=

PUBLIC_IMAGE_HOST=
IMAGE_HOST=
