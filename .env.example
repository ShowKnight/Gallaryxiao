# Public site URL — controls sitemap canonical, OG tags.
# Set on Cloudflare Pages: Project → Settings → Environment variables.
SITE_URL=https://shellyxiao.com

# Volcano veImageX CDN host for this service.
# Find it in 火山引擎 console → veImageX → 服务 → "访问域名".
# Example: tos-cn-i-abc1234.volccdn.com
PUBLIC_IMAGE_HOST=tos-cn-i-XXXX.volccdn.com

# (also expose to astro.config — same value as PUBLIC_IMAGE_HOST)
IMAGE_HOST=tos-cn-i-XXXX.volccdn.com
