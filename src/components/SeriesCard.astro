---
import type { CollectionEntry } from "astro:content";
import { type Lang, pick, pathFor, useTranslations } from "~/i18n/ui";
import Img from "~/components/Img.astro";

interface Props {
  series: CollectionEntry<"series">;
  lang: Lang;
  /** Larger feature card (used on home / featured slot) */
  feature?: boolean;
}

const { series, lang, feature = false } = Astro.props;
const t = useTranslations(lang);
const title = pick(series.data, "title", lang);
const coverAlt = pick(series.data, "cover_alt", lang) || title;
const yearLabel = series.data.year_end
  ? `${series.data.year_start}–${series.data.year_end}`
  : `${series.data.year_start}–${t("meta.ongoing")}`;
const href = pathFor(lang, `/works/${series.id}`);
---

<a
  href={href}
  class:list={[
    "group block hover:!border-b-transparent",
    feature ? "" : "",
  ]}
>
  <div class:list={[feature ? "aspect-[3/2]" : "aspect-[4/5]", "overflow-hidden bg-[var(--color-line)]"]}>
    <Img
      src={series.data.cover}
      alt={coverAlt}
      preset="medium"
      class="h-full w-full object-cover transition-[opacity] duration-500 group-hover:opacity-90"
    />
  </div>
  <div class="mt-4 flex items-baseline justify-between gap-4">
    <h3 class:list={["font-serif", feature ? "text-2xl md:text-3xl" : "text-xl"]}>
      {title}
    </h3>
    <span class="meta whitespace-nowrap">{yearLabel}</span>
  </div>
</a>
