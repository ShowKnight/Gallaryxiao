---
import { type Lang, useTranslations, pathFor, localelessPath } from "~/i18n/ui";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

// Switch to the other language, preserving the current path.
const otherLang: Lang = lang === "zh" ? "en" : "zh";
const here = localelessPath(Astro.url.pathname);
const switchHref = pathFor(otherLang, here);

const siteName = lang === "zh" ? "无名工作室" : "Untitled Studio";

const nav = [
  { to: "/works", label: t("nav.works") },
  { to: "/journal", label: t("nav.journal") },
  { to: "/about", label: t("nav.about") },
  { to: "/contact", label: t("nav.contact") },
];
---

<header class="border-b border-[var(--color-line)] bg-[var(--color-paper)]">
  <div class="mx-auto max-w-[72rem] flex items-baseline justify-between px-6 py-6 md:py-8">
    <a
      href={pathFor(lang, "/")}
      class="font-serif text-[1.25rem] tracking-wide hover:!border-b-transparent"
    >
      {siteName}
    </a>
    <nav class="flex items-baseline gap-6 text-[0.95rem]">
      {nav.map((item) => (
        <a
          href={pathFor(lang, item.to)}
          class="text-[var(--color-ink)]"
          aria-current={here.startsWith(item.to) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
      <a
        href={switchHref}
        class="meta hover:!border-b-transparent"
        aria-label={otherLang === "zh" ? "切换到中文" : "Switch to English"}
      >
        {t("lang.switch")}
      </a>
    </nav>
  </div>
</header>
