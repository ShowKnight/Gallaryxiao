---
import "~/styles/global.css";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";
import { type Lang, getLangFromUrl } from "~/i18n/ui";

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  /** Use a wider container (e.g. for index pages with grids) */
  wide?: boolean;
}

const { title, description = "", wide = false } = Astro.props;
const lang: Lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const siteName = lang === "zh" ? "无名工作室" : "Untitled Studio"; // placeholder
const fullTitle = title ? `${title} — ${siteName}` : siteName;
---

<!doctype html>
<html lang={lang === "zh" ? "zh-CN" : "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} type="image/svg+xml" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:type" content="website" />
    {description && <meta property="og:description" content={description} />}
  </head>
  <body>
    <Header lang={lang} />
    <main class:list={["mx-auto", wide ? "max-w-[88rem]" : "max-w-[72rem]"]}>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
